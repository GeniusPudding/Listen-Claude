# ListenClaude runtime config

# Master switch — set to 0 to disable TTS without uninstalling.
TTS_ENABLED=1

# Engine: "system" (built-in OS TTS), "piper" (local), or "elevenlabs" (cloud).
TTS_ENGINE=system

# Voice identifier (engine-specific):
#   system + macOS:   say -v name (e.g. Mei-Jia, Tingting, Sin-ji)
#   system + Windows: SAPI voice name (e.g. "Microsoft Yating Desktop")
#   piper:            voice .onnx filename or short name in PIPER_VOICES_DIR
#   elevenlabs:       voice_id from https://elevenlabs.io/app/voice-library
TTS_VOICE=

# Required only for TTS_ENGINE=elevenlabs.
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Reading mode:
#   full    — read the entire last assistant message
#   first   — read only the first paragraph
#   summary — heuristic summary (headers + first sentence per paragraph)
TTS_MODE=first

# Skip TTS for messages with fewer words than this.
TTS_MIN_WORDS=20

# Truncate longer messages to this many characters.
TTS_MAX_CHARS=500

# Rough words-per-minute (engine-specific mapping).
TTS_RATE=200

# Piper: directory holding .onnx + .onnx.json voice files.
# PIPER_VOICES_DIR=~/.cache/piper-voices
